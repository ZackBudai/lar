{"name":"modus_ponens","axioms":["forall x. (Human(x) -> Mortal(x))","Human(Socrates)"],"query":"Mortal(Socrates)","expected":true}
{"name":"not_entailed_simple","axioms":["forall x. (Human(x) -> Mortal(x))","Human(Plato)"],"query":"Mortal(Socrates)","expected":false}
{"name":"family_transitive","axioms":["forall x. forall y. forall z. ((Parent(x,y) & Parent(y,z)) -> Grandparent(x,z))","Parent(Alice,Bob)","Parent(Bob,Charlie)"],"query":"Grandparent(Alice,Charlie)","expected":true}
{"name":"ancestor_recursive","axioms":["forall x. forall y. (Parent(x,y) -> Ancestor(x,y))","forall x. forall y. forall z. ((Parent(x,y) & Ancestor(y,z)) -> Ancestor(x,z))","Parent(A,B)","Parent(B,C)","Parent(C,D)"],"query":"Ancestor(A,D)","expected":true}
{"name":"likes_exists","axioms":["forall x. exists y. Likes(x,y)"],"query":"exists y. Likes(A,y)","expected":true}
{"name":"query_with_function","axioms":["forall x. (P(x) -> P(f(x)))","P(A)"],"query":"P(f(f(A)))","expected":true}
{"name":"bird_penguin","axioms":["forall x. (Penguin(x) -> Bird(x))","forall x. (Bird(x) -> HasWings(x))","Penguin(Tux)"],"query":"HasWings(Tux)","expected":true}
{"name":"independent_predicates","axioms":["forall x. (A1(x) -> A2(x))","A1(K)"],"query":"B1(K)","expected":false}
{"name":"chain_depth_4","axioms":["forall x. forall y. (R(x,y) -> Reach(x,y))","forall x. forall y. forall z. ((R(x,y) & Reach(y,z)) -> Reach(x,z))","R(N1,N2)","R(N2,N3)","R(N3,N4)","R(N4,N5)"],"query":"Reach(N1,N5)","expected":true}
{"name":"non_entailed_chain","axioms":["forall x. forall y. (R(x,y) -> Reach(x,y))","forall x. forall y. forall z. ((R(x,y) & Reach(y,z)) -> Reach(x,z))","R(N1,N2)","R(N2,N3)"],"query":"Reach(N1,N5)","expected":false}
